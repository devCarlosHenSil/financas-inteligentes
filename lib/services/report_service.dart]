import 'package:financas_inteligentes/models/goal_model.dart';
import 'package:financas_inteligentes/models/investment_model.dart';
import 'package:financas_inteligentes/models/provento_model.dart';
import 'package:financas_inteligentes/models/transaction_model.dart';
import 'package:intl/intl.dart';
import 'package:pdf/pdf.dart';
import 'package:pdf/widgets.dart' as pw;
import 'package:printing/printing.dart';

/// Serviço de geração de relatórios PDF para o Finanças Inteligentes.
///
/// ## Relatórios disponíveis
/// - [printTransactions]  → Extrato de transações do mês
/// - [printInvestments]   → Carteira de investimentos
/// - [printProventos]     → Histórico de proventos/dividendos
/// - [printGoals]         → Resumo de metas financeiras
/// - [printFullReport]    → Relatório completo consolidado
///
/// ## Uso
/// ```dart
/// await ReportService.instance.printTransactions(
///   transactions: provider.transactions,
///   userLabel: auth.displayLabel,
/// );
/// ```
class ReportService {
  ReportService._();
  static final ReportService instance = ReportService._();

  // ── Formatadores ──────────────────────────────────────────────────────────

  final _currency  = NumberFormat.currency(locale: 'pt_BR', symbol: 'R\$');
  final _dateShort = DateFormat('dd/MM/yyyy');
  final _dateMonth = DateFormat('MMMM yyyy', 'pt_BR');

  // ── Paleta de cores do app em PdfColor ────────────────────────────────────

  static final _primary    = PdfColor.fromHex('1D4ED8');
  static final _success    = PdfColor.fromHex('059669');
  static final _error      = PdfColor.fromHex('DC2626');
  static final _warning    = PdfColor.fromHex('D97706');
  static final _surface    = PdfColor.fromHex('F8FAFC');
  static final _border     = PdfColor.fromHex('E2E8F0');
  static final _textDark   = PdfColor.fromHex('0F172A');
  static final _textMuted  = PdfColor.fromHex('64748B');
  static final _white      = PdfColors.white;

  // =========================================================================
  // API pública
  // =========================================================================

  /// Abre o diálogo de impressão/compartilhamento para o extrato de transações.
  Future<void> printTransactions({
    required List<TransactionModel> transactions,
    required String userLabel,
    DateTime? mes,
  }) async {
    final doc = await _buildTransactionsDoc(
      transactions: transactions,
      userLabel: userLabel,
      mes: mes ?? DateTime.now(),
    );
    await Printing.layoutPdf(
      onLayout: (_) async => doc.save(),
      name: 'extrato_${DateFormat('yyyy_MM').format(mes ?? DateTime.now())}.pdf',
    );
  }

  /// Alias de [printTransactions] — compatibilidade com telas que chamam
  /// `ReportService.instance.exportarTransacoes(...)`.
  Future<void> exportarTransacoes({
    required List<TransactionModel> transactions,
    required String userLabel,
    DateTime? mes,
  }) =>
      printTransactions(
        transactions: transactions,
        userLabel: userLabel,
        mes: mes,
      );

  /// Abre o diálogo de impressão para a carteira de investimentos.
  Future<void> printInvestments({
    required List<InvestmentModel> investments,
    required String userLabel,
  }) async {
    final doc = await _buildInvestmentsDoc(
      investments: investments,
      userLabel: userLabel,
    );
    await Printing.layoutPdf(
      onLayout: (_) async => doc.save(),
      name: 'investimentos_${DateFormat('yyyy_MM_dd').format(DateTime.now())}.pdf',
    );
  }

  /// Abre o diálogo de impressão para o histórico de proventos.
  Future<void> printProventos({
    required List<ProventoModel> proventos,
    required String userLabel,
  }) async {
    final doc = await _buildProventosDoc(
      proventos: proventos,
      userLabel: userLabel,
    );
    await Printing.layoutPdf(
      onLayout: (_) async => doc.save(),
      name: 'proventos_${DateFormat('yyyy_MM_dd').format(DateTime.now())}.pdf',
    );
  }

  /// Abre o diálogo de impressão para o resumo de metas.
  Future<void> printGoals({
    required List<GoalModel> goals,
    required String userLabel,
  }) async {
    final doc = await _buildGoalsDoc(goals: goals, userLabel: userLabel);
    await Printing.layoutPdf(
      onLayout: (_) async => doc.save(),
      name: 'metas_${DateFormat('yyyy_MM_dd').format(DateTime.now())}.pdf',
    );
  }

  /// Relatório completo consolidado (todas as seções).
  Future<void> printFullReport({
    required List<TransactionModel> transactions,
    required List<InvestmentModel> investments,
    required List<ProventoModel> proventos,
    required List<GoalModel> goals,
    required String userLabel,
  }) async {
    final doc = pw.Document();
    final now = DateTime.now();

    // Capa
    doc.addPage(_buildCoverPage(userLabel: userLabel, date: now));

    // Seção: Transações
    final txPages = await _transactionPages(
        transactions: transactions, userLabel: userLabel, mes: now);
    for (final page in txPages) {
      doc.addPage(page);
    }

    // Seção: Investimentos
    final invPages = await _investmentPages(
        investments: investments, userLabel: userLabel);
    for (final page in invPages) {
      doc.addPage(page);
    }

    // Seção: Proventos
    final provPages = await _proventoPages(
        proventos: proventos, userLabel: userLabel);
    for (final page in provPages) {
      doc.addPage(page);
    }

    // Seção: Metas
    final goalPages = await _goalPages(goals: goals, userLabel: userLabel);
    for (final page in goalPages) {
      doc.addPage(page);
    }

    await Printing.layoutPdf(
      onLayout: (_) async => doc.save(),
      name: 'relatorio_completo_${DateFormat('yyyy_MM_dd').format(now)}.pdf',
    );
  }

  // =========================================================================
  // Builders de documentos
  // =========================================================================

  Future<pw.Document> _buildTransactionsDoc({
    required List<TransactionModel> transactions,
    required String userLabel,
    required DateTime mes,
  }) async {
    final doc = pw.Document();
    final pages = await _transactionPages(
        transactions: transactions, userLabel: userLabel, mes: mes);
    for (final page in pages) {
      doc.addPage(page);
    }
    return doc;
  }

  Future<pw.Document> _buildInvestmentsDoc({
    required List<InvestmentModel> investments,
    required String userLabel,
  }) async {
    final doc = pw.Document();
    final pages =
        await _investmentPages(investments: investments, userLabel: userLabel);
    for (final page in pages) {
      doc.addPage(page);
    }
    return doc;
  }

  Future<pw.Document> _buildProventosDoc({
    required List<ProventoModel> proventos,
    required String userLabel,
  }) async {
    final doc = pw.Document();
    final pages =
        await _proventoPages(proventos: proventos, userLabel: userLabel);
    for (final page in pages) {
      doc.addPage(page);
    }
    return doc;
  }

  Future<pw.Document> _buildGoalsDoc({
    required List<GoalModel> goals,
    required String userLabel,
  }) async {
    final doc = pw.Document();
    final pages = await _goalPages(goals: goals, userLabel: userLabel);
    for (final page in pages) {
      doc.addPage(page);
    }
    return doc;
  }

  // =========================================================================
  // Páginas: Transações
  // =========================================================================

  Future<List<pw.Page>> _transactionPages({
    required List<TransactionModel> transactions,
    required String userLabel,
    required DateTime mes,
  }) async {
    final mesLabel = _capitalize(_dateMonth.format(mes));
    final filtered = transactions
        .where((t) => t.data.month == mes.month && t.data.year == mes.year)
        .toList()
      ..sort((a, b) => b.data.compareTo(a.data));

    final totalEntradas = filtered
        .where((t) => t.tipo == 'entrada')
        .fold(0.0, (s, t) => s + t.valor);
    final totalSaidas = filtered
        .where((t) => t.tipo == 'saida')
        .fold(0.0, (s, t) => s + t.valor);
    final saldo = totalEntradas - totalSaidas;

    return [
      pw.MultiPage(
        pageFormat: PdfPageFormat.a4,
        margin: const pw.EdgeInsets.all(32),
        header: (ctx) => _pageHeader(
          title: 'Extrato de Transações',
          subtitle: mesLabel,
          userLabel: userLabel,
          pageNumber: ctx.pageNumber,
          pagesCount: ctx.pagesCount,
        ),
        footer: (_) => _pageFooter(),
        build: (ctx) => [
          // KPIs
          _kpiRow([
            _KpiItem('Entradas', _currency.format(totalEntradas), _success),
            _KpiItem('Saídas',   _currency.format(totalSaidas),   _error),
            _KpiItem(
              'Saldo',
              _currency.format(saldo),
              saldo >= 0 ? _success : _error,
            ),
          ]),
          pw.SizedBox(height: 16),

          // Tabela
          if (filtered.isEmpty)
            _emptyState('Nenhuma transação no período.')
          else
            _table(
              headers: ['Data', 'Categoria', 'Tipo', 'Fixa', 'Valor'],
              rows: filtered.map((t) => [
                _dateShort.format(t.data),
                t.categoria,
                t.tipo == 'entrada' ? 'Entrada' : 'Saída',
                t.fixa ? 'Sim' : 'Não',
                _currency.format(t.valor),
              ]).toList(),
              columnWidths: {
                0: const pw.FixedColumnWidth(68),
                1: const pw.FlexColumnWidth(3),
                2: const pw.FixedColumnWidth(56),
                3: const pw.FixedColumnWidth(40),
                4: const pw.FixedColumnWidth(80),
              },
              rowColor: (index) {
                final t = filtered[index];
                if (t.tipo == 'entrada') {
                  return PdfColor.fromHex('F0FDF4');
                }
                return index.isEven ? _surface : _white;
              },
            ),
        ],
      ),
    ];
  }

  // =========================================================================
  // Páginas: Investimentos
  // =========================================================================

  Future<List<pw.Page>> _investmentPages({
    required List<InvestmentModel> investments,
    required String userLabel,
  }) async {
    final sorted = [...investments]
      ..sort((a, b) => b.data.compareTo(a.data));

    final totalAplicado = investments
        .where((i) => i.valorInvestido > 0)
        .fold(0.0, (s, i) => s + i.valorInvestido);
    final totalResgatado = investments
        .where((i) => i.valorInvestido < 0)
        .fold(0.0, (s, i) => s + i.valorInvestido.abs());
    final patrimonio = investments.fold(0.0, (s, i) => s + i.valorInvestido);

    // Distribuição por tipo
    final dist = <String, double>{};
    for (final inv in investments) {
      final tipo = inv.nome.split('•').first.trim();
      dist.update(tipo, (v) => v + inv.valorInvestido,
          ifAbsent: () => inv.valorInvestido);
    }
    dist.removeWhere((_, v) => v <= 0);

    return [
      pw.MultiPage(
        pageFormat: PdfPageFormat.a4,
        margin: const pw.EdgeInsets.all(32),
        header: (ctx) => _pageHeader(
          title: 'Carteira de Investimentos',
          subtitle: 'Gerado em ${_dateShort.format(DateTime.now())}',
          userLabel: userLabel,
          pageNumber: ctx.pageNumber,
          pagesCount: ctx.pagesCount,
        ),
        footer: (_) => _pageFooter(),
        build: (_) => [
          _kpiRow([
            _KpiItem('Patrimônio',  _currency.format(patrimonio),   _primary),
            _KpiItem('Aplicado',    _currency.format(totalAplicado), _success),
            _KpiItem('Resgatado',   _currency.format(totalResgatado),_warning),
            _KpiItem('Lançamentos', investments.length.toString(),   _textMuted),
          ]),
          pw.SizedBox(height: 16),

          // Distribuição por tipo
          if (dist.isNotEmpty) ...[
            _sectionTitle('Distribuição por Tipo de Ativo'),
            pw.SizedBox(height: 8),
            _table(
              headers: ['Tipo de Ativo', 'Total Aplicado', '% Carteira'],
              rows: dist.entries.map((e) {
                final pct = patrimonio > 0
                    ? (e.value / patrimonio * 100).toStringAsFixed(1)
                    : '0.0';
                return [e.key, _currency.format(e.value), '$pct%'];
              }).toList(),
              columnWidths: {
                0: const pw.FlexColumnWidth(3),
                1: const pw.FixedColumnWidth(100),
                2: const pw.FixedColumnWidth(70),
              },
            ),
            pw.SizedBox(height: 16),
          ],

          // Lançamentos
          _sectionTitle('Histórico de Lançamentos'),
          pw.SizedBox(height: 8),
          if (sorted.isEmpty)
            _emptyState('Nenhum lançamento cadastrado.')
          else
            _table(
              headers: ['Data', 'Ativo', 'Operação', 'Valor'],
              rows: sorted.map((inv) {
                final parts = inv.nome.split('•').map((e) => e.trim()).toList();
                final ativo = parts.length > 1 ? parts[1] : inv.nome;
                final operacao = parts.length > 2
                    ? parts[2]
                    : (inv.valorInvestido >= 0 ? 'Compra' : 'Venda');
                return [
                  _dateShort.format(inv.data),
                  ativo,
                  operacao,
                  _currency.format(inv.valorInvestido),
                ];
              }).toList(),
              columnWidths: {
                0: const pw.FixedColumnWidth(68),
                1: const pw.FlexColumnWidth(3),
                2: const pw.FixedColumnWidth(60),
                3: const pw.FixedColumnWidth(90),
              },
              rowColor: (index) {
                final inv = sorted[index];
                if (inv.valorInvestido < 0) return PdfColor.fromHex('FFF7ED');
                return index.isEven ? _surface : _white;
              },
            ),
        ],
      ),
    ];
  }

  // =========================================================================
  // Páginas: Proventos
  // =========================================================================

  Future<List<pw.Page>> _proventoPages({
    required List<ProventoModel> proventos,
    required String userLabel,
  }) async {
    final sorted = [...proventos]
      ..sort((a, b) => b.dataPagamento.compareTo(a.dataPagamento));

    final totalPago = proventos
        .where((p) => p.status.toLowerCase().contains('pago'))
        .fold(0.0, (s, p) => s + p.valorTotal);
    final totalPendente = proventos
        .where((p) => !p.status.toLowerCase().contains('pago'))
        .fold(0.0, (s, p) => s + p.valorTotal);

    return [
      pw.MultiPage(
        pageFormat: PdfPageFormat.a4,
        margin: const pw.EdgeInsets.all(32),
        header: (ctx) => _pageHeader(
          title: 'Proventos e Dividendos',
          subtitle: 'Gerado em ${_dateShort.format(DateTime.now())}',
          userLabel: userLabel,
          pageNumber: ctx.pageNumber,
          pagesCount: ctx.pagesCount,
        ),
        footer: (_) => _pageFooter(),
        build: (_) => [
          _kpiRow([
            _KpiItem('Total Recebido',  _currency.format(totalPago),     _success),
            _KpiItem('A Receber',       _currency.format(totalPendente),  _warning),
            _KpiItem('Total Carteira',  _currency.format(totalPago + totalPendente), _primary),
            _KpiItem('Qtd. Registros',  proventos.length.toString(),      _textMuted),
          ]),
          pw.SizedBox(height: 16),

          if (sorted.isEmpty)
            _emptyState('Nenhum provento cadastrado.')
          else
            _table(
              headers: [
                'Pagamento', 'Ativo', 'Tipo', 'Status', 'Qtd.', 'Valor Unit.', 'Total'
              ],
              rows: sorted.map((p) => [
                _dateShort.format(p.dataPagamento),
                p.ativo,
                p.tipoPagamento,
                p.status,
                p.quantidade.toStringAsFixed(2),
                _currency.format(p.valorDiv),
                _currency.format(p.valorTotal),
              ]).toList(),
              columnWidths: {
                0: const pw.FixedColumnWidth(64),
                1: const pw.FlexColumnWidth(2),
                2: const pw.FlexColumnWidth(2),
                3: const pw.FixedColumnWidth(56),
                4: const pw.FixedColumnWidth(44),
                5: const pw.FixedColumnWidth(68),
                6: const pw.FixedColumnWidth(68),
              },
              rowColor: (index) {
                final p = sorted[index];
                final isPago = p.status.toLowerCase().contains('pago');
                if (isPago) return PdfColor.fromHex('F0FDF4');
                return index.isEven ? _surface : _white;
              },
            ),
        ],
      ),
    ];
  }

  // =========================================================================
  // Páginas: Metas
  // =========================================================================

  Future<List<pw.Page>> _goalPages({
    required List<GoalModel> goals,
    required String userLabel,
  }) async {
    final active    = goals.where((g) => g.isActive).toList();
    final completed = goals.where((g) => g.status == GoalStatus.completed).toList();
    final archived  = goals.where((g) => g.isArchived).toList();

    final totalTarget  = active.fold(0.0, (s, g) => s + g.targetValue);
    final totalCurrent = active.fold(0.0, (s, g) => s + g.currentValue);
    final avgProgress  = active.isEmpty
        ? 0.0
        : active.fold(0.0, (s, g) => s + g.progress) / active.length;

    return [
      pw.MultiPage(
        pageFormat: PdfPageFormat.a4,
        margin: const pw.EdgeInsets.all(32),
        header: (ctx) => _pageHeader(
          title: 'Metas Financeiras',
          subtitle: 'Gerado em ${_dateShort.format(DateTime.now())}',
          userLabel: userLabel,
          pageNumber: ctx.pageNumber,
          pagesCount: ctx.pagesCount,
        ),
        footer: (_) => _pageFooter(),
        build: (_) => [
          _kpiRow([
            _KpiItem('Metas Ativas',    active.length.toString(),                     _primary),
            _KpiItem('Acumulado',       _currency.format(totalCurrent),               _success),
            _KpiItem('Alvo Total',      _currency.format(totalTarget),                _warning),
            _KpiItem('Progresso Médio', '${(avgProgress * 100).toStringAsFixed(0)}%', _textMuted),
          ]),
          pw.SizedBox(height: 16),

          if (active.isNotEmpty) ...[
            _sectionTitle('Metas Ativas'),
            pw.SizedBox(height: 8),
            _goalsTable(active),
            pw.SizedBox(height: 16),
          ],

          if (completed.isNotEmpty) ...[
            _sectionTitle('Metas Concluídas'),
            pw.SizedBox(height: 8),
            _goalsTable(completed),
            pw.SizedBox(height: 16),
          ],

          if (archived.isNotEmpty) ...[
            _sectionTitle('Metas Arquivadas'),
            pw.SizedBox(height: 8),
            _goalsTable(archived),
          ],

          if (goals.isEmpty)
            _emptyState('Nenhuma meta cadastrada.'),
        ],
      ),
    ];
  }

  pw.Widget _goalsTable(List<GoalModel> goals) {
    return _table(
      headers: ['Meta', 'Tipo', 'Acumulado', 'Alvo', 'Progresso', 'Prazo'],
      rows: goals.map((g) => [
        g.title,
        g.typeLabel,
        _currency.format(g.currentValue),
        _currency.format(g.targetValue),
        '${g.progressPercent.toStringAsFixed(0)}%',
        g.deadline != null ? _dateShort.format(g.deadline!) : '—',
      ]).toList(),
      columnWidths: {
        0: const pw.FlexColumnWidth(3),
        1: const pw.FlexColumnWidth(2),
        2: const pw.FixedColumnWidth(72),
        3: const pw.FixedColumnWidth(72),
        4: const pw.FixedColumnWidth(54),
        5: const pw.FixedColumnWidth(60),
      },
      rowColor: (index) {
        final g = goals[index];
        if (g.isCompleted) return PdfColor.fromHex('F0FDF4');
        if (g.isOverdue)   return PdfColor.fromHex('FEF2F2');
        return index.isEven ? _surface : _white;
      },
    );
  }

  // =========================================================================
  // Capa do relatório completo
  // =========================================================================

  pw.Page _buildCoverPage({
    required String userLabel,
    required DateTime date,
  }) {
    return pw.Page(
      pageFormat: PdfPageFormat.a4,
      margin: const pw.EdgeInsets.all(48),
      build: (_) => pw.Column(
        crossAxisAlignment: pw.CrossAxisAlignment.start,
        children: [
          pw.Spacer(),
          pw.Container(
            width: double.infinity,
            padding: const pw.EdgeInsets.all(32),
            decoration: pw.BoxDecoration(
              color: _primary,
              borderRadius: pw.BorderRadius.circular(12),
            ),
            child: pw.Column(
              crossAxisAlignment: pw.CrossAxisAlignment.start,
              children: [
                pw.Text(
                  'Finanças Inteligentes',
                  style: pw.TextStyle(
                    color: _white,
                    fontSize: 28,
                    fontWeight: pw.FontWeight.bold,
                  ),
                ),
                pw.SizedBox(height: 8),
                pw.Text(
                  'Relatório Financeiro Completo',
                  style: pw.TextStyle(color: _white, fontSize: 16),
                ),
                pw.SizedBox(height: 24),
                pw.Text(
                  userLabel,
                  style: pw.TextStyle(
                    color: PdfColor.fromHex('BFDBFE'),
                    fontSize: 14,
                  ),
                ),
                pw.Text(
                  'Gerado em ${_dateShort.format(date)} às ${DateFormat('HH:mm').format(date)}',
                  style: pw.TextStyle(
                    color: PdfColor.fromHex('BFDBFE'),
                    fontSize: 12,
                  ),
                ),
              ],
            ),
          ),
          pw.Spacer(flex: 2),
          pw.Text(
            'Este relatório é gerado automaticamente pelo aplicativo\n'
            'Finanças Inteligentes e contém dados confidenciais.',
            style: pw.TextStyle(color: _textMuted, fontSize: 10),
          ),
        ],
      ),
    );
  }

  // =========================================================================
  // Widgets internos reutilizáveis
  // =========================================================================

  pw.Widget _pageHeader({
    required String title,
    required String subtitle,
    required String userLabel,
    required int pageNumber,
    required int pagesCount,
  }) {
    return pw.Column(
      crossAxisAlignment: pw.CrossAxisAlignment.start,
      children: [
        pw.Row(
          mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
          children: [
            pw.Column(
              crossAxisAlignment: pw.CrossAxisAlignment.start,
              children: [
                pw.Text(
                  title,
                  style: pw.TextStyle(
                    color: _primary,
                    fontSize: 18,
                    fontWeight: pw.FontWeight.bold,
                  ),
                ),
                pw.Text(
                  subtitle,
                  style: pw.TextStyle(color: _textMuted, fontSize: 10),
                ),
              ],
            ),
            pw.Column(
              crossAxisAlignment: pw.CrossAxisAlignment.end,
              children: [
                pw.Text(
                  'Finanças Inteligentes',
                  style: pw.TextStyle(
                    color: _primary,
                    fontSize: 10,
                    fontWeight: pw.FontWeight.bold,
                  ),
                ),
                pw.Text(
                  userLabel,
                  style: pw.TextStyle(color: _textMuted, fontSize: 9),
                ),
                pw.Text(
                  'Pág. $pageNumber / $pagesCount',
                  style: pw.TextStyle(color: _textMuted, fontSize: 9),
                ),
              ],
            ),
          ],
        ),
        pw.SizedBox(height: 4),
        pw.Divider(color: _border, thickness: 1),
        pw.SizedBox(height: 8),
      ],
    );
  }

  pw.Widget _pageFooter() {
    return pw.Column(
      children: [
        pw.Divider(color: _border, thickness: 0.5),
        pw.SizedBox(height: 4),
        pw.Row(
          mainAxisAlignment: pw.MainAxisAlignment.spaceBetween,
          children: [
            pw.Text(
              'Finanças Inteligentes — Relatório confidencial',
              style: pw.TextStyle(color: _textMuted, fontSize: 8),
            ),
            pw.Text(
              'Gerado em ${_dateShort.format(DateTime.now())}',
              style: pw.TextStyle(color: _textMuted, fontSize: 8),
            ),
          ],
        ),
      ],
    );
  }

  pw.Widget _kpiRow(List<_KpiItem> items) {
    return pw.Row(
      children: items.map((item) {
        return pw.Expanded(
          child: pw.Container(
            margin: const pw.EdgeInsets.only(right: 8),
            padding: const pw.EdgeInsets.all(10),
            decoration: pw.BoxDecoration(
              border: pw.Border.all(color: _border),
              borderRadius: pw.BorderRadius.circular(6),
              color: _surface,
            ),
            child: pw.Column(
              crossAxisAlignment: pw.CrossAxisAlignment.start,
              children: [
                pw.Text(
                  item.label,
                  style: pw.TextStyle(color: _textMuted, fontSize: 9),
                ),
                pw.SizedBox(height: 4),
                pw.Text(
                  item.value,
                  style: pw.TextStyle(
                    color: item.color,
                    fontSize: 13,
                    fontWeight: pw.FontWeight.bold,
                  ),
                ),
              ],
            ),
          ),
        );
      }).toList(),
    );
  }

  pw.Widget _sectionTitle(String title) {
    return pw.Text(
      title,
      style: pw.TextStyle(
        color: _primary,
        fontSize: 12,
        fontWeight: pw.FontWeight.bold,
      ),
    );
  }

  pw.Widget _emptyState(String message) {
    return pw.Container(
      width: double.infinity,
      padding: const pw.EdgeInsets.all(24),
      decoration: pw.BoxDecoration(
        color: _surface,
        border: pw.Border.all(color: _border),
        borderRadius: pw.BorderRadius.circular(6),
      ),
      child: pw.Text(
        message,
        textAlign: pw.TextAlign.center,
        style: pw.TextStyle(color: _textMuted, fontSize: 11),
      ),
    );
  }

  pw.Widget _table({
    required List<String> headers,
    required List<List<String>> rows,
    Map<int, pw.TableColumnWidth>? columnWidths,
    PdfColor Function(int index)? rowColor,
  }) {
    return pw.Table(
      columnWidths: columnWidths,
      border: pw.TableBorder.all(color: _border, width: 0.5),
      children: [
        // Cabeçalho
        pw.TableRow(
          decoration: pw.BoxDecoration(color: _primary),
          children: headers
              .map(
                (h) => pw.Padding(
                  padding: const pw.EdgeInsets.symmetric(
                      horizontal: 6, vertical: 5),
                  child: pw.Text(
                    h,
                    style: pw.TextStyle(
                      color: _white,
                      fontSize: 9,
                      fontWeight: pw.FontWeight.bold,
                    ),
                  ),
                ),
              )
              .toList(),
        ),
        // Linhas de dados
        ...rows.asMap().entries.map((entry) {
          final index = entry.key;
          final row   = entry.value;
          final bg    = rowColor?.call(index) ??
              (index.isEven ? _surface : _white);

          return pw.TableRow(
            decoration: pw.BoxDecoration(color: bg),
            children: row
                .map(
                  (cell) => pw.Padding(
                    padding: const pw.EdgeInsets.symmetric(
                        horizontal: 6, vertical: 4),
                    child: pw.Text(
                      cell,
                      style: pw.TextStyle(
                        color: _textDark,
                        fontSize: 9,
                      ),
                    ),
                  ),
                )
                .toList(),
          );
        }),
      ],
    );
  }

  // ── Helpers internos ──────────────────────────────────────────────────────

  String _capitalize(String s) =>
      s.isEmpty ? s : s[0].toUpperCase() + s.substring(1);
}

