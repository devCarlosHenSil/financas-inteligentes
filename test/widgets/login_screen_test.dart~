// ignore_for_file: avoid_relative_lib_imports

import 'package:financas_inteligentes/providers/auth_provider.dart'
    as app_auth;
import 'package:financas_inteligentes/screens/login_screen.dart';
import 'package:flutter/material.dart';
import 'package:flutter_test/flutter_test.dart';
import 'package:provider/provider.dart';

class _FakeAuth extends app_auth.AuthProvider {
  bool _loading       = false;
  String? _error;
  bool _authenticated = false;
  bool _nextResult    = true;

  @override
  bool    get isLoading       => _loading;
  @override
  String? get errorMessage    => _error;
  @override
  bool    get isAuthenticated => _authenticated;

  void setNextResult({required bool success, String? error}) {
    _nextResult = success;
    _error      = error;
  }

  @override
  Future<bool> signIn({required String email, required String password}) async {
    _loading = true;
    notifyListeners();
    await Future.delayed(const Duration(milliseconds: 30));
    _loading = false;
    if (_nextResult) { _authenticated = true; _error = null; }
    notifyListeners();
    return _nextResult;
  }

  @override
  Future<bool> register({required String email, required String password}) async {
    _loading = true;
    notifyListeners();
    await Future.delayed(const Duration(milliseconds: 30));
    _loading = false;
    if (_nextResult) { _authenticated = true; _error = null; }
    notifyListeners();
    return _nextResult;
  }

  @override
  void clearError() { _error = null; notifyListeners(); }
}

Widget _buildApp(_FakeAuth fakeAuth) {
  return ChangeNotifierProvider<app_auth.AuthProvider>.value(
    value: fakeAuth,
    child: const MaterialApp(home: LoginScreen()),
  );
}

void main() {
  group('LoginScreen — estrutura visual', () {
    late _FakeAuth fakeAuth;
    setUp(() => fakeAuth = _FakeAuth());

    testWidgets('exibe dois campos TextField', (t) async {
      await t.pumpWidget(_buildApp(fakeAuth));
      expect(find.byType(TextField), findsAtLeastNWidgets(2));
    });

    testWidgets('exibe botão Entrar', (t) async {
      await t.pumpWidget(_buildApp(fakeAuth));
      expect(find.text('Entrar'), findsOneWidget);
    });

    testWidgets('exibe botão Criar conta', (t) async {
      await t.pumpWidget(_buildApp(fakeAuth));
      expect(find.text('Criar conta'), findsOneWidget);
    });

    testWidgets('exibe ícone da carteira', (t) async {
      await t.pumpWidget(_buildApp(fakeAuth));
      expect(find.byIcon(Icons.account_balance_wallet_rounded), findsOneWidget);
    });

    testWidgets('exibe título Bem-vindo de volta', (t) async {
      await t.pumpWidget(_buildApp(fakeAuth));
      expect(find.text('Bem-vindo de volta'), findsOneWidget);
    });
  });

  group('LoginScreen — validação de campos vazios', () {
    late _FakeAuth fakeAuth;
    setUp(() => fakeAuth = _FakeAuth());

    testWidgets('snackbar ao Entrar com campos vazios', (t) async {
      await t.pumpWidget(_buildApp(fakeAuth));
      await t.tap(find.text('Entrar'));
      await t.pump();
      expect(find.text('Preencha e-mail e senha para continuar.'), findsOneWidget);
    });

    testWidgets('snackbar ao Criar conta com campos vazios', (t) async {
      await t.pumpWidget(_buildApp(fakeAuth));
      await t.tap(find.text('Criar conta'));
      await t.pump();
      expect(find.text('Preencha e-mail e senha para cadastrar.'), findsOneWidget);
    });
  });

  group('LoginScreen — fluxo de login', () {
    late _FakeAuth fakeAuth;
    setUp(() => fakeAuth = _FakeAuth());

    testWidgets('sem snackbar de campos vazios quando dados preenchidos', (t) async {
      await t.pumpWidget(_buildApp(fakeAuth));
      final fields = find.byType(TextField);
      await t.enterText(fields.at(0), 'usuario@teste.com');
      await t.enterText(fields.at(1), 'senha123');
      await t.tap(find.text('Entrar'));
      await t.pump();
      expect(find.text('Preencha e-mail e senha para continuar.'), findsNothing);
    });

    testWidgets('exibe erro quando signIn retorna false', (t) async {
      fakeAuth.setNextResult(success: false, error: 'E-mail ou senha incorretos.');
      await t.pumpWidget(_buildApp(fakeAuth));
      final fields = find.byType(TextField);
      await t.enterText(fields.at(0), 'usuario@teste.com');
      await t.enterText(fields.at(1), 'senhaerrada');
      await t.tap(find.text('Entrar'));
      await t.pump(const Duration(milliseconds: 200));
      expect(find.text('E-mail ou senha incorretos.'), findsOneWidget);
    });
  });

  group('LoginScreen — toggle visibilidade de senha', () {
    testWidgets('alterna ícone de visibilidade', (t) async {
      final fakeAuth = _FakeAuth();
      await t.pumpWidget(_buildApp(fakeAuth));
      expect(find.byIcon(Icons.visibility_outlined), findsOneWidget);
      await t.tap(find.byIcon(Icons.visibility_outlined));
      await t.pump();
      expect(find.byIcon(Icons.visibility_off_outlined), findsOneWidget);
      await t.tap(find.byIcon(Icons.visibility_off_outlined));
      await t.pump();
      expect(find.byIcon(Icons.visibility_outlined), findsOneWidget);
    });
  });

  group('LoginScreen — estado de loading', () {
    testWidgets('botão Entrar habilitado quando não carregando', (t) async {
      final fakeAuth = _FakeAuth();
      await t.pumpWidget(_buildApp(fakeAuth));
      final btn = t.widget<FilledButton>(
        find.widgetWithText(FilledButton, 'Entrar'),
      );
      expect(btn.onPressed, isNotNull);
    });
  });
}
